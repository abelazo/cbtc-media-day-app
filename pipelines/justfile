# Pipelines management recipes

# CBTC players and tutors pipelines
mod players-tutors 'players_tutors'

# Players data uploader pipeline
mod player-data-uploader 'player_data_uploader'

# Default recipe - show available commands
help:
    @just --list

# Run all pipeline tests
test-all:
    @echo "Running all pipeline tests..."
    cd player_data_uploader && uv run pytest
    cd players_tutors && uv run pytest
    @echo "All pipeline tests passed"

# Lint all pipelines
lint-all:
    @echo "Linting all pipelines..."
    uv run ruff check .
    uv run black --check .
    @echo "All pipelines linted"

# Format all pipelines
format-all:
    @echo "Formatting all pipelines..."
    uv run black .
    uv run ruff check --fix .
    @echo "All pipelines formatted"
