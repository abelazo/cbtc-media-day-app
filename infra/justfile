# Infrastructure management recipes

# Bootstrap stack
[group('stacks')]
mod bootstrap

# Global stack (lambda-sources bucket, content bucket, users table, signing)
[group('stacks')]
mod global

# API Gateway stack (REST API + integrations to lambdas)
[group('stacks')]
mod api-gateway

# Default recipe - show available commands
help:
  @just --list

# Clean all modules
[group('clean')]
clean-all:
  #!/usr/bin/env bash
  echo "Cleaning all modules..."
  for module in $(ls); do
    if [ -d "$module" ]; then
      (cd "$module" && just clean)
    fi
  done
